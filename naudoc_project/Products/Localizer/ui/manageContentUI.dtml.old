<dtml-call "REQUEST.set('management_screens', _.SecurityCheckPermission('View management screens', this()))">

<dtml-if management_screens>
  <dtml-var manage_page_header>
  <dtml-var manage_tabs>
<dtml-else>
  <dtml-var standard_html_header>
</dtml-if>


<dtml-unless "REQUEST.has_key('batch_start')">
  <dtml-call "REQUEST.set('batch_start', 0)"></dtml-unless>
<dtml-unless "REQUEST.has_key('batch_size')">
  <dtml-call "REQUEST.set('batch_size', 100)"></dtml-unless>
<dtml-unless "REQUEST.has_key('language')">
  <dtml-call "REQUEST.set('language', '')"></dtml-unless>
<dtml-unless "REQUEST.has_key('status')">
  <dtml-call "REQUEST.set('status', 1)"></dtml-unless>



<dtml-with "get_content(batch_start, batch_size, REQUEST['language'], status)" mapping>
<dtml-let batch_end="batch_start + batch_size">


<form action="<dtml-var URL>" method="get">
 <input type="hidden" name="batch_start:int" value="<dtml-var batch_start>">
 <table>
  <tr>
   <th align="left"><dtml-var "gettext('Batch size')"></th>
   <th> &nbsp; </th>
   <th align="left"><dtml-var "gettext('Pending languages')"></th>
   <th> &nbsp; </th>
   <th align="left"><dtml-var "gettext('Status')"></th>
   <th> &nbsp; </th>
   <th></th>
  </tr>
  <tr>
   <td><input type="text" name="batch_size:int" size="3"
              value="<dtml-var batch_size>"></td>
   <td> &nbsp; </td>
   <td>
     <select name="language">
       <option value=""></option>
       <dtml-in "Localizer.get_supported_languages()">
         <option value="<dtml-var sequence-item>"
                 <dtml-if "REQUEST['language'] == _['sequence-item']"> selected</dtml-if>>
           <dtml-var "gettext(Localizer[_['sequence-item']].title)"></option>
       </dtml-in>
     </select>
   </td>
   <td> &nbsp; </td>
   <td>
     <input type="radio" name="status:int" value="0"<dtml-if "not status"> checked</dtml-if>>
     <dtml-var "gettext('All')">
     <input type="radio" name="status:int" value="1"<dtml-if status> checked</dtml-if>>
     <dtml-var "gettext('Only valid')">
   </td>
   <td> &nbsp; </td>
   <td>
     <input type="submit" value=" <dtml-var "gettext('Filter')"> ">
   </td>
  </tr>
 </table>
</form>


<table cellspacing="0" cellpadding="2" border="0">
 <tr>
  <td colspan="3">
   <dtml-var "gettext('Results')"> <dtml-var "batch_start + 1">-<dtml-if "batch_end < nentries"><dtml-var batch_end><dtml-else><dtml-var nentries></dtml-if> <dtml-var "gettext('of')"> <dtml-var nentries>

   <dtml-let search="'language=%s&status:int=%s' % (REQUEST['language'], _.str(REQUEST['status']))">
     <dtml-if "batch_start > 0">
      <a href="<dtml-var URL>?batch_start:int=<dtml-var "batch_start - batch_size">&amp;batch_size:int=<dtml-var batch_size>&<dtml-var search>"><dtml-var "gettext('Previous')"></a>
     </dtml-if>
     <dtml-if "batch_start + 10 < nentries">
      <a href="<dtml-var URL>?batch_start:int=<dtml-var "batch_start + batch_size">&amp;batch_size:int=<dtml-var batch_size>&<dtml-var search>"><dtml-var "gettext('Next')"></a>
     </dtml-if>
   </dtml-let>
  </td>
 </tr>
</table>


<dtml-in content>
  <dtml-let site_root="Localizer.aq_inner.aq_parent.absolute_url()"
           url="getURL()[_.len(site_root)+1:]">
    <a href="<dtml-var url>/<dtml-if management_screens>manage_LPs<dtml-else>manage_content</dtml-if>">
      <dtml-if "_.has_key('custom_content_title')">
        <dtml-var "custom_content_title(getObject())">
      <dtml-else>
        <dtml-var "getObject().title_or_id()">
      </dtml-if>
    </a><br>
  </dtml-let>
</dtml-in>


</dtml-let>
</dtml-with>


<dtml-if management_screens>
  <dtml-var manage_page_footer>
<dtml-else>
  <dtml-var standard_html_footer>
</dtml-if>
