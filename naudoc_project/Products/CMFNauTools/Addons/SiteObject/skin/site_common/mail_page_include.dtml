<dtml-let cur_obj="_.hasattr(this(), 'getCurrentObject') and getCurrentObject() or this()">
<a href="mailto:?subject=ссылка на страницу '<dtml-var "cur_obj.title_or_id()">'&body=<dtml-var "URL + '/' + (_.string.join(_.getattr(REQUEST, 'traverse_subpath', ''), '/'))">">Послать ссылку другу</a>
</dtml-let>
