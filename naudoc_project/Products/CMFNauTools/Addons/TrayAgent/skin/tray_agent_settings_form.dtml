<dtml-comment>
$Editor: ikuleshov $
$Id: tray_agent_settings_form.dtml,v 1.3 2004/12/17 09:11:02 ikuleshov Exp $
</dtml-comment>
<dtml-revision $Revision: 1.3 $>

<dtml-var simple_html_header>

<dtml-let member="portal_membership.getAuthenticatedMember()">

 <dtml-if "not portal_membership.checkPermission( 'Set own properties', this() )">
   <dtml-raise Unauthorized>
     You must be logged in to view this resource.
   </dtml-raise>
  </dtml-if>

<div class="Desktop">

<h1> <dtml-msg "Tray agent settings"> </h1>


<form action="tray_agent_settings" method="post">

 <h3><dtml-msg trayagent.checking_settings_header></h3>
 <table class="FormLayout">
  <tr>
   <th><dtml-msg trayagent.startup_check></th>
   <td><input type="checkbox" name="ta_check_on_startup:boolean"
              value="1" <dtml-var "member.getProperty( 'ta_check_on_startup' )" fmt=checked>
       >
       <input type="hidden" name="ta_check_on_startup:boolean:default"
              value=""
       >
   </td>
  </tr>
   <th><dtml-msg trayagent.periodical_check></th>
   <td><input type="text" size="3" name="ta_check_interval:int"
              value="<dtml-var "member.getProperty( 'ta_check_interval' )" html_quote>">
       <dtml-msg min>
   </td>
  </tr>
 </table>

<br>

<h3><dtml-msg trayagent.actions_settings_header></h3>
 <table class="FormLayout">
  <tr>
   <th><dtml-msg trayagent.play_sound></th>
   <td><input type="checkbox" name="ta_sound_alert:boolean"
              value="1" <dtml-var "member.getProperty( 'ta_sound_alert' )" fmt=checked>
       >
       <input type="hidden" name="ta_sound_alert:boolean:default"
              value=""
       >
   </td>
  </tr>
  <tr>
   <th><dtml-msg trayagent.show_browser></th>
   <td><input type="checkbox" name="ta_open_browser:boolean"
              value="1" <dtml-var "member.getProperty( 'ta_open_browser' )" fmt=checked>
       >
       <input type="hidden" name="ta_open_browser:boolean:default"
              value=""
       >
   </td>
  </tr>
  <tr>
   <th><dtml-msg trayagent.show_balloon_tip></th>
   <td><input type="checkbox" name="ta_balloon_tips:boolean"
              value="1" <dtml-var "member.getProperty( 'ta_balloon_tips' )" fmt=checked>
       >
       <input type="hidden" name="ta_balloon_tips:boolean:default"
              value=""
       >
   </td>
  </tr>
 </table>
<br>

<input type="submit" value=" <dtml-msg Save> ">
</form>

<dtml-msgtext>trayagent.download<dtml-msgparam click_here><a href="&dtml-portal_url;/trayagent/NauDoc-TrayAgent-1.1-Install.exe"><dtml-msg trayagent.click_here></a></dtml-msgtext>


</dtml-let>

</div>

<dtml-var simple_html_footer>
