<dtml-if "lang=='en'">
Subject: Information about task "<dtml-var task_title>"

You are a supervisor of task "<dtml-var task_title>"
URL: &dtml-task_url;
<dtml-else>
Subject: Назначено задание "<dtml-var task_title>"
Content-Type: text/plain; charset=windows-1251

Вы назначены контролером задания "<dtml-var task_title>"
URL: &dtml-task_url;
</dtml-if>
