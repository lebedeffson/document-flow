<dtml-comment>
$Id: external_edit_link.dtml,v 1.11 2004/05/27 14:13:19 ypetrov Exp $
</dtml-comment>
<dtml-revision $Revision: 1.11 $>

<dtml-let ee_action="portal_actions.getAction('external_edit', ignore_permissions=0 )">
<dtml-if ee_action>
  <dtml-with ee_action mapping>
    <a class="toolbar-button" href="&dtml-url;">
      <img src="&dtml-portal_url;/&dtml-icon;" alt="<dtml-msg expr=name>" width="16" height="16"></a>
  </dtml-with>
</dtml-if>
</dtml-let>
