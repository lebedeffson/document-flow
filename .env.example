# Production-oriented environment template for the hospital deployment.
# Copy to `.env` and replace all demo/default values before launch.

PROJECT_ROOT=/opt/docflow

# Public URLs
GATEWAY_SERVER_NAME=docflow.hospital.local
GATEWAY_EXTERNAL_HTTPS_PORT=443
GATEWAY_EXTERNAL_HTTP_SUFFIX=
GATEWAY_EXTERNAL_HTTPS_SUFFIX=
GATEWAY_EXTERNAL_HTTPS_SUFFIX_ESCAPED=
GATEWAY_TLS_CN=docflow.hospital.local
GATEWAY_BIND_HTTP_PORT=80
GATEWAY_BIND_HTTPS_PORT=443
RUKOVODITEL_BIND_PORT=18081
BRIDGE_BIND_PORT=18082
NAUDOC_BIND_PORT=18080
ONLYOFFICE_BIND_PORT=18083
RUKOVODITEL_PUBLIC_URL=https://docflow.hospital.local
NAUDOC_PUBLIC_URL=https://docflow.hospital.local/docs
DOCSPACE_PUBLIC_URL=https://docflow.hospital.local/docspace
WORKSPACE_PUBLIC_URL=https://docflow.hospital.local/workspace
BRIDGE_BASE_URL=http://host.docker.internal:18082
RUKOVODITEL_BASE_URL=http://host.docker.internal:18081
NAUDOC_BASE_URL=http://host.docker.internal:18080/docs
SYNC_CONTROL_URL=http://host.docker.internal:18081/run_sync_job.php
ONLYOFFICE_INTEGRATION_BASE_URL=http://rukovoditel
ONLYOFFICE_PUBLIC_JS_API_URL=https://docflow.hospital.local/office/web-apps/apps/api/documents/api.js
DOCSPACE_ENABLED=1
WORKSPACE_ENABLED=1
DOCSPACE_TARGET_URL=
WORKSPACE_TARGET_URL=
DOCFLOW_OFFICE_WAVE1_REQUIRE_LIVE_TARGETS=0

# Upstreams for gateway
GATEWAY_RUKOVODITEL_UPSTREAM=host.docker.internal:18081
GATEWAY_BRIDGE_UPSTREAM=host.docker.internal:18082
GATEWAY_NAUDOC_UPSTREAM=host.docker.internal:18080
GATEWAY_NAUDOC_UPSTREAM_ESCAPED=host.docker.internal%3A18080
GATEWAY_ONLYOFFICE_UPSTREAM=host.docker.internal:18083

# Image tags for offline/portable deployment
GATEWAY_IMAGE=docflow/gateway:local
BRIDGE_IMAGE=docflow/bridge:local
RUKOVODITEL_APP_IMAGE=docflow/rukovoditel-app:local
NAUDOC_LEGACY_IMAGE=docflow/naudoc-legacy:local
MARIADB_IMAGE=mariadb:10.11
ONLYOFFICE_IMAGE=onlyoffice/documentserver:latest
LDAP_IMAGE=osixia/openldap:1.5.0

# Database and secrets
RUKOVODITEL_DB_NAME=rukovoditel
RUKOVODITEL_DB_USER=rukovoditel
RUKOVODITEL_DB_PASSWORD=CHANGE_ME_DB_PASSWORD
RUKOVODITEL_DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
NAUDOC_USERNAME=admin
NAUDOC_PASSWORD=CHANGE_ME_NAUDOC_PASSWORD
BRIDGE_SYNC_CONTROL_TOKEN=CHANGE_ME_SYNC_TOKEN
ONLYOFFICE_JWT_SECRET=CHANGE_ME_ONLYOFFICE_JWT
LDAP_DOMAIN=hospital.local
LDAP_ORGANISATION=Hospital_DocFlow
LDAP_ADMIN_PASSWORD=CHANGE_ME_LDAP_ADMIN_PASSWORD
LDAP_CONFIG_PASSWORD=CHANGE_ME_LDAP_CONFIG_PASSWORD
LDAP_BIND_PASSWORD=CHANGE_ME_LDAP_BIND_PASSWORD
LDAP_CONTAINER_NAME=docflow_hospital_ldap

# Verification and login-mode toggles
DOCFLOW_SHOW_DEMO_LOGIN_MODES=0
DOCFLOW_ADMIN_USERNAME=admin
DOCFLOW_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
DOCFLOW_ROLE_DEFAULT_PASSWORD=CHANGE_ME_ROLE_PASSWORD
DOCFLOW_MANAGER_USERNAME=department.head
DOCFLOW_EMPLOYEE_USERNAME=clinician.primary
DOCFLOW_REQUESTER_USERNAME=registry.operator
DOCFLOW_OFFICE_USERNAME=records.office
DOCFLOW_NURSE_USERNAME=nurse.coordinator

# Runtime
SYNC_INTERVAL_SECONDS=60
BRIDGE_REQUEST_TIMEOUT=8
BRIDGE_DB_PATH=/data/bridge.db

# Container names used by ops scripts
GATEWAY_CONTAINER_NAME=docflow_gateway
GATEWAY_COMPOSE_PROJECT_NAME=docflow_gateway
BRIDGE_CONTAINER=docflow_bridge
RUKOVODITEL_CONTAINER_NAME=docflow_rukovoditel
RUKOVODITEL_DB_CONTAINER=docflow_rukovoditel_db
ONLYOFFICE_CONTAINER_NAME=docflow_onlyoffice_docs
RUKOVODITEL_SYNC_WORKER_CONTAINER_NAME=docflow_sync_worker
NAUDOC_LEGACY_CONTAINER=docflow_naudoc_legacy
MIDDLEWARE_COMPOSE_PROJECT_NAME=docflow_middleware
RUKOVODITEL_COMPOSE_PROJECT_NAME=docflow_rukovoditel
NAUDOC_LEGACY_COMPOSE_PROJECT=docflow_legacy
NAUDOC_LEGACY_SERVICE=naudoc_legacy
